DATABASE_URL="file:./dev.db"
SESSION_SECRET="replace-me-with-a-long-random-string"
PYTHON_BIN=".venv/bin/python"
AI_COMMENT_MODEL="gpt-5.4"
ANTHROPIC_API_KEY=""
# Optional server-wide default agent model when a document has none configured.
# Accepts a canonical Anthropic id (claude-sonnet-5 / claude-fable-5 /
# claude-opus-4-8) or an OpenRouter model as openrouter/<author>/<model>.
# CLAUDE_AGENT_MODEL="claude-sonnet-5"
# NOTE: OPENROUTER_API_KEY is NOT a server env var — it is a per-document
# secret set via the document's Env menu (DocumentEnvVar) and unlocks the
# OpenRouter section of the model selector for that document.
# Canonical public origin. Used to build redirect/share URLs and to allow-list
# the X-Forwarded-Host header (prevents host-header open redirects that could
# leak share tokens). e.g. https://docs.nielsrolf.com
APP_URL="http://localhost:14141"
# Optional comma-separated extra hosts to trust in X-Forwarded-Host.
# ALLOWED_HOSTS="docs.nielsrolf.com,localhost:14141"
