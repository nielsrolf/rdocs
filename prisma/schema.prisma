generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  name              String
  passwordHash      String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  ownedDocuments    Document[]           @relation("DocumentOwner")
  memberships       DocumentMembership[]
  comments          Comment[]
  createdShareLinks ShareLink[]
  createdThreads    CommentThread[]
  threadReads       CommentThreadRead[]
  commentReactions  CommentReaction[]
  mentions          CommentMention[]
  documentMentions  DocumentMention[]
}

model Document {
  id              String               @id @default(cuid())
  title           String
  content         String
  ownerId         String
  repoUrl         String?
  repoBranch      String?
  repoWorkspace   String?
  activeAiRunId   String?
  agentModel      String?
  agentEffort     String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  owner           User                 @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships     DocumentMembership[]
  threads         CommentThread[]
  shareLinks      ShareLink[]
  versions        DocumentVersion[]
  aiRuns          AiRun[]
  embeddedWidgets EmbeddedWidget[]
  envVars         DocumentEnvVar[]
  documentMentions DocumentMention[]
  attachments     Attachment[]
}

// User-uploaded files attached to a document. The bytes live on disk under the
// per-document attachments dir (see lib/attachments.ts); this row holds the
// metadata. Each attachment is rendered as a draggable chip in the document and
// copied into the agent's worktree at `attachments/<storedName>` so the agent can
// read it. `storedName` is sanitized + unique within the document.
model Attachment {
  id          String   @id @default(cuid())
  documentId  String
  fileName    String
  storedName  String
  mimeType    String
  size        Int
  createdById String?
  createdAt   DateTime @default(now())
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
}

// Per-document secrets injected into the agent's environment (LLM API keys, GPU
// provisioning tokens, etc.). Values are write-only over the API — listed back
// masked, never in full. See lib/agent-env.ts for how they reach the agent.
model DocumentEnvVar {
  id         String   @id @default(cuid())
  documentId String
  key        String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, key])
}

model DocumentMembership {
  id         String   @id @default(cuid())
  documentId String
  userId     String
  permission String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
}

model CommentThread {
  id            String    @id @default(cuid())
  documentId    String
  // Null when the thread was started by an anonymous share-link visitor.
  createdById   String?
  anchorText    String
  anchorContext String?
  status        String    @default("OPEN")
  tags          String    @default("[]")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  document      Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy     User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  comments      Comment[]
  reads         CommentThreadRead[]
}

model CommentThreadRead {
  id         String        @id @default(cuid())
  threadId   String
  userId     String
  lastReadAt DateTime      @default(now())
  thread     CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId])
}

model Comment {
  id          String        @id @default(cuid())
  threadId    String
  authorId    String?
  // Display name for anonymous share-link commenters (authorId null, no aiModel).
  guestName   String?
  body        String
  aiModel     String?
  sourceLinks String?
  commitSha   String?
  commitUrl   String?
  aiRunId     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  thread      CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author      User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  aiRun       AiRun?        @relation(fields: [aiRunId], references: [id], onDelete: SetNull)
  reactions   CommentReaction[]
  mentions    CommentMention[]
}

// Emoji reactions on a comment. One row per (comment, user, emoji); toggling a
// reaction the user already has removes it.
model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
}

// A user @mentioned in a comment. `acknowledged` flips true once the mentioned
// user has seen it (opening the document); the dashboard surfaces unacknowledged
// mentions per document, mirroring unread comments.
model CommentMention {
  id              String   @id @default(cuid())
  commentId       String
  documentId      String
  mentionedUserId String
  acknowledged    Boolean  @default(false)
  createdAt       DateTime @default(now())
  comment         Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUser   User     @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([commentId, mentionedUserId])
  @@index([mentionedUserId, acknowledged])
  @@index([documentId])
}

// An @mention typed into the document BODY (vs. a comment). Recorded when a
// mention is inserted via the editor autocomplete so the mentioned member gets
// the same dashboard badge as a comment mention. One row per (document, user)
// — re-inserting refreshes its unacknowledged state via upsert.
model DocumentMention {
  id              String   @id @default(cuid())
  documentId      String
  mentionedUserId String
  acknowledged    Boolean  @default(false)
  createdAt       DateTime @default(now())
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  mentionedUser   User     @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([documentId, mentionedUserId])
  @@index([mentionedUserId, acknowledged])
  @@index([documentId])
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  title       String
  content     String
  sourceLinks String?
  commitSha   String?
  commitUrl   String?
  aiRunId     String?
  createdAt   DateTime @default(now())
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  aiRun       AiRun?   @relation(fields: [aiRunId], references: [id], onDelete: SetNull)

  @@index([documentId, createdAt])
}

model AiRun {
  id            String            @id @default(cuid())
  documentId    String
  triggerType   String
  triggerId     String?
  parentRunId   String?
  instruction   String
  status        String            @default("RUNNING")
  progress      String?
  model         String?
  workspacePath String?
  branchName    String?
  commitSha     String?
  commitUrl     String?
  error         String?
  startedAt     DateTime          @default(now())
  finishedAt    DateTime?
  selectionId        String?
  replacementText    String?
  replacementImages  String?
  replacementWidgets String?
  replacementSources String?
  suggestions        String?
  agentComments      String?
  suggestOnly        Boolean           @default(false)
  appliedAt          DateTime?
  document      Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  parentRun     AiRun?            @relation("AiRunFollowUps", fields: [parentRunId], references: [id], onDelete: SetNull)
  followUps     AiRun[]           @relation("AiRunFollowUps")
  comments      Comment[]
  versions      DocumentVersion[]
  events        AiRunEvent[]

  @@index([documentId, startedAt])
  @@index([documentId, status])
  @@index([parentRunId])
}

model AiRunEvent {
  id        String   @id @default(cuid())
  aiRunId   String
  role      String
  message   String
  createdAt DateTime @default(now())
  aiRun     AiRun    @relation(fields: [aiRunId], references: [id], onDelete: Cascade)

  @@index([aiRunId, createdAt])
}

model EmbeddedWidget {
  id            String    @id @default(cuid())
  documentId    String
  label         String
  buildCmd      String
  embedSource   String
  createdByRunId String?
  workspacePath String?
  lastBuiltAt   DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  document      Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
}

model CollaborationStep {
  documentId String
  version    Int
  step       String
  clientId   String
  createdAt  DateTime @default(now())

  @@id([documentId, version])
  @@index([documentId, version])
}

model ShareLink {
  id          String    @id @default(cuid())
  token       String    @unique
  documentId  String
  createdById String
  permission  String
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
}
