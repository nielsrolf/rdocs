generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  name              String
  passwordHash      String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  ownedDocuments    Document[]           @relation("DocumentOwner")
  memberships       DocumentMembership[]
  comments          Comment[]
  createdShareLinks ShareLink[]
  createdThreads    CommentThread[]
  threadReads       CommentThreadRead[]
  commentReactions  CommentReaction[]
  mentions          CommentMention[]
  documentMentions  DocumentMention[]
  credentials       UserCredential[]
  apiTokens         ApiToken[]
  skills            UserSkill[]
  slackLinks        SlackAccountLink[]
  aiRuns            AiRun[]              @relation("AiRunCreator")
  scheduledTasks    ScheduledTask[]
}

// A reusable agent skill in a user's personal library (a directory with a
// SKILL.md plus supporting files, Claude Agent SDK format). Files live on disk
// under the per-user skill store (see lib/skills.ts); this row holds metadata.
// `name` is the sanitized skill directory name. Skills marked `isDefault` are
// copied into every document the user creates.
model UserSkill {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

// An agent skill attached to a document. Files live on disk under the
// per-document skill store and are materialized into `.claude/skills/<name>`
// in every agent worktree; the run enables exactly these skills by name.
model DocumentSkill {
  id          String   @id @default(cuid())
  documentId  String
  name        String
  description String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, name])
}

// Per-user AI credentials, at most one per provider; every document the user
// OWNS inherits them, and the agent runs under the owner's credential (see
// lib/user-credentials.ts). `provider` is "anthropic" | "openrouter" |
// "litellm". `kind` is "api_key" (a plain API key — the only kind for
// openrouter/litellm) or "oauth" (a `claude setup-token` subscription token,
// anthropic only). `secret` is the value encrypted at rest with
// CREDENTIAL_ENCRYPTION_KEY (AES-256-GCM) — never returned in full over the
// API; listed back masked, like DocumentEnvVar.
model UserCredential {
  id        String   @id @default(cuid())
  userId    String
  provider  String   @default("anthropic")
  kind      String
  secret    String
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// Personal access tokens for the MCP bridge (`/api/mcp`). The plaintext token
// (`gdai_<hex>`) is shown ONCE at creation and only its SHA-256 hex digest is
// stored; resolution is a hash lookup (see lib/api-tokens.ts). Revocation is a
// soft delete via `revokedAt` so the row keeps its audit trail.
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  label      String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Document {
  id              String               @id @default(cuid())
  title           String
  content         String
  // "document" (default) or "slack_channel". A slack_channel document is the
  // per-channel agent workspace behind the Slack bot: same model/skills/env
  // config surface, rendered differently in the dashboard. Slack ids identify
  // the backing channel; one document per (team, channel).
  kind            String               @default("document")
  slackTeamId     String?
  slackChannelId  String?
  ownerId         String
  repoUrl         String?
  repoBranch      String?
  repoWorkspace   String?
  activeAiRunId   String?
  agentModel      String?
  agentEffort     String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  owner           User                 @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships     DocumentMembership[]
  threads         CommentThread[]
  shareLinks      ShareLink[]
  versions        DocumentVersion[]
  aiRuns          AiRun[]
  embeddedWidgets EmbeddedWidget[]
  envVars         DocumentEnvVar[]
  documentMentions DocumentMention[]
  attachments     Attachment[]
  skills          DocumentSkill[]
  scheduledTasks  ScheduledTask[]

  @@unique([slackTeamId, slackChannelId])
}

// Links a Slack identity to a gdocs-ai account so bot runs triggered by a
// Slack mention execute with the mentioning user's credentials (runnerUserId
// in lib/user-credentials.ts). One link per Slack identity per team.
model SlackAccountLink {
  id            String   @id @default(cuid())
  slackTeamId   String
  slackUserId   String
  userId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([slackTeamId, slackUserId])
  @@index([userId])
}

// User-uploaded files attached to a document. The bytes live on disk under the
// per-document attachments dir (see lib/attachments.ts); this row holds the
// metadata. Each attachment is rendered as a draggable chip in the document and
// copied into the agent's worktree at `attachments/<storedName>` so the agent can
// read it. `storedName` is sanitized + unique within the document.
model Attachment {
  id          String   @id @default(cuid())
  documentId  String
  fileName    String
  storedName  String
  mimeType    String
  size        Int
  createdById String?
  createdAt   DateTime @default(now())
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
}

// Per-document secrets injected into the agent's environment (LLM API keys, GPU
// provisioning tokens, etc.). Values are write-only over the API — listed back
// masked, never in full. See lib/agent-env.ts for how they reach the agent.
model DocumentEnvVar {
  id         String   @id @default(cuid())
  documentId String
  key        String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, key])
}

model DocumentMembership {
  id         String   @id @default(cuid())
  documentId String
  userId     String
  permission String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
}

model CommentThread {
  id            String    @id @default(cuid())
  documentId    String
  // Null when the thread was started by an anonymous share-link visitor.
  createdById   String?
  anchorText    String
  anchorContext String?
  status        String    @default("OPEN")
  tags          String    @default("[]")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  document      Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy     User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  comments      Comment[]
  reads         CommentThreadRead[]
}

model CommentThreadRead {
  id         String        @id @default(cuid())
  threadId   String
  userId     String
  lastReadAt DateTime      @default(now())
  thread     CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId])
}

model Comment {
  id          String        @id @default(cuid())
  threadId    String
  authorId    String?
  // Display name for anonymous share-link commenters (authorId null, no aiModel).
  guestName   String?
  body        String
  aiModel     String?
  sourceLinks String?
  commitSha   String?
  commitUrl   String?
  aiRunId     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  thread      CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author      User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  aiRun       AiRun?        @relation(fields: [aiRunId], references: [id], onDelete: SetNull)
  reactions   CommentReaction[]
  mentions    CommentMention[]
}

// Emoji reactions on a comment. One row per (comment, user, emoji); toggling a
// reaction the user already has removes it.
model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
}

// A user @mentioned in a comment. `acknowledged` flips true once the mentioned
// user has seen it (opening the document); the dashboard surfaces unacknowledged
// mentions per document, mirroring unread comments.
model CommentMention {
  id              String   @id @default(cuid())
  commentId       String
  documentId      String
  mentionedUserId String
  acknowledged    Boolean  @default(false)
  createdAt       DateTime @default(now())
  comment         Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUser   User     @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([commentId, mentionedUserId])
  @@index([mentionedUserId, acknowledged])
  @@index([documentId])
}

// An @mention typed into the document BODY (vs. a comment). Recorded when a
// mention is inserted via the editor autocomplete so the mentioned member gets
// the same dashboard badge as a comment mention. One row per (document, user)
// — re-inserting refreshes its unacknowledged state via upsert.
model DocumentMention {
  id              String   @id @default(cuid())
  documentId      String
  mentionedUserId String
  acknowledged    Boolean  @default(false)
  createdAt       DateTime @default(now())
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  mentionedUser   User     @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([documentId, mentionedUserId])
  @@index([mentionedUserId, acknowledged])
  @@index([documentId])
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  title       String
  content     String
  sourceLinks String?
  commitSha   String?
  commitUrl   String?
  aiRunId     String?
  createdAt   DateTime @default(now())
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  aiRun       AiRun?   @relation(fields: [aiRunId], references: [id], onDelete: SetNull)

  @@index([documentId, createdAt])
}

model AiRun {
  id            String            @id @default(cuid())
  documentId    String
  triggerType   String
  triggerId     String?
  // The user whose request started this run (and whose credentials it ran
  // with). Null for legacy rows and share-link visitors. Powers the activity
  // overview ("who did what where").
  createdById   String?
  parentRunId   String?
  instruction   String
  status        String            @default("RUNNING")
  progress      String?
  model         String?
  workspacePath String?
  branchName    String?
  commitSha     String?
  commitUrl     String?
  error         String?
  startedAt     DateTime          @default(now())
  finishedAt    DateTime?
  // Process-liveness heartbeat ticked by the in-process runner while the run
  // executes. Distinguishes "quiet but alive" (long tool waits emit no
  // AiRunEvents) from "owning server died" for the stale-run reaper.
  heartbeatAt   DateTime?
  selectionId        String?
  // The document text that was selected when a SELECTION_EDIT run started
  // (truncated). The live marker can vanish long before anyone reads the run
  // history, so the agent view needs its own copy to show what the run was on.
  selectedText       String?
  replacementText    String?
  replacementImages  String?
  replacementWidgets String?
  replacementSources String?
  suggestions        String?
  agentComments      String?
  suggestOnly        Boolean           @default(false)
  appliedAt          DateTime?
  document      Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy     User?             @relation("AiRunCreator", fields: [createdById], references: [id], onDelete: SetNull)
  parentRun     AiRun?            @relation("AiRunFollowUps", fields: [parentRunId], references: [id], onDelete: SetNull)
  followUps     AiRun[]           @relation("AiRunFollowUps")
  comments      Comment[]
  versions      DocumentVersion[]
  events        AiRunEvent[]

  @@index([documentId, startedAt])
  @@index([documentId, status])
  @@index([parentRunId])
}

model AiRunEvent {
  id        String   @id @default(cuid())
  aiRunId   String
  role      String
  message   String
  createdAt DateTime @default(now())
  aiRun     AiRun    @relation(fields: [aiRunId], references: [id], onDelete: Cascade)

  @@index([aiRunId, createdAt])
}

// A recurring or one-shot agent task scheduled from Slack (schedule_task
// tool). Fired by the poll loop in lib/scheduler.ts: each firing starts a
// normal conversation AiRun in the stored context (a Slack thread by default,
// or the channel top-level) with the CREATOR's identity/credentials. Creation
// is announced in the channel and any channel member can cancel — a recurring
// task silently burning someone's API key is the failure mode this guards.
model ScheduledTask {
  id             String    @id @default(cuid())
  documentId     String
  createdById    String?
  createdByRunId String?
  instruction    String
  // "slack_thread" (reply into the stored thread) or "slack_channel" (post
  // top-level, starting a fresh thread per firing).
  contextType    String
  slackTeamId    String
  slackChannelId String
  slackThreadTs  String?
  // Recurring: a 5-field cron expression. One-shot: null cron, nextRunAt only.
  cron           String?
  timezone       String?
  nextRunAt      DateTime
  lastFiredAt    DateTime?
  lastRunId      String?
  disabledAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  document       Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy      User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([nextRunAt, disabledAt])
  @@index([documentId])
}

model EmbeddedWidget {
  id            String    @id @default(cuid())
  documentId    String
  label         String
  buildCmd      String
  embedSource   String
  createdByRunId String?
  workspacePath String?
  lastBuiltAt   DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  document      Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
}

model CollaborationStep {
  documentId String
  version    Int
  step       String
  clientId   String
  createdAt  DateTime @default(now())

  @@id([documentId, version])
  @@index([documentId, version])
}

model ShareLink {
  id          String    @id @default(cuid())
  token       String    @unique
  documentId  String
  createdById String
  permission  String
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
}
